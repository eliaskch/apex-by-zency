# =============================================================================
# APEX by Zency — Variables de production VPS
# Copier ce fichier en .env.prod et remplir les valeurs
# =============================================================================

# --- PostgreSQL ---
POSTGRES_USER=apex
POSTGRES_PASSWORD=CHANGER_MOT_DE_PASSE_FORT
POSTGRES_DB=apex_db

# --- Redis ---
REDIS_PASSWORD=CHANGER_MOT_DE_PASSE_REDIS

# --- MinIO (stockage S3) ---
MINIO_ROOT_USER=apexadmin
MINIO_ROOT_PASSWORD=CHANGER_MOT_DE_PASSE_MINIO

# --- Backend FastAPI ---
SECRET_KEY=GENERER_AVEC_openssl_rand_hex_32
ENVIRONMENT=production
ALLOWED_ORIGINS=https://apex.votre-domaine.fr

# --- APIs IA ---
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=

# --- Domaine (pour le SSL) ---
DOMAIN=apex.votre-domaine.fr
