# =============================================================
# APEX by Zency — Variables d'environnement
# Copier ce fichier en backend/.env et remplir les valeurs
# NE JAMAIS COMMITTER LE VRAI .env
# =============================================================

# --- Backend ---
DATABASE_URL=postgresql+asyncpg://apex:apex@localhost:5432/apex_db
REDIS_URL=redis://localhost:6379/0

# Générer avec : openssl rand -hex 32
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32

# APIs IA
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Stockage S3-compatible (MinIO en dev)
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=apex-dev
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1

# Environnement
ENVIRONMENT=development

# --- Frontend (.env.local) ---
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# --- Production uniquement ---
# POSTGRES_USER=apex_prod
# POSTGRES_PASSWORD=<mot-de-passe-fort>
# POSTGRES_DB=apex_db
# REDIS_PASSWORD=<mot-de-passe-fort>
# MINIO_ROOT_USER=<user>
# MINIO_ROOT_PASSWORD=<mot-de-passe-fort>
